#!/usr/bin/env bash
#
ZOXIDE_RESULT=$(zoxide query -l | fzf --reverse )

# if empty exit
if [ -z "$ZOXIDE_RESULT" ]; then
	exit 0
fi

# Get directory name
DIR=$(basename $ZOXIDE_RESULT)

# Lookup tmux session name
TMUX_SESSION=$(tmux list-sessions | grep $DIR | awk '{print $1}')
TMUX_SESSION=${TMUX_SESSION//:/} echo "$TMUX_SESSION"
#
if [ -z "$TMUX" ]; then

	if [ -z "$TMUX_SESSION" ]; then
		cd $ZOXIDE_RESULT
		tmux new-session -s $DIR
	else
		tmux attach -t $TMUX_SESSION
	fi
else
	if [ -z "$TMUX_SESSION" ]; then
		cd $ZOXIDE_RESULT
		tmux new-session -d -s $DIR
		tmux switch-client -t $DIR
	else
		tmux switch-client -t $TMUX_SESSION
	fi
fi
	

